# Linear integration (required for pipeline/daemon)
# Get from: https://linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# Linear workspace slug (optional, enables Linear links in auto-created PRs)
# Find it in your Linear URL: https://linear.app/<workspace>/...
# WERMA_LINEAR_WORKSPACE=myorg

# Slack notifications (optional)
SLACK_BOT_TOKEN=xoxb-...

# GitHub token (optional, for self-update / private repo access)
# Uses GITHUB_TOKEN or GH_TOKEN from environment
# GITHUB_TOKEN=ghp_...
